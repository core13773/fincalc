# Copy this file to `.env` and fill in after Google setup.
# Variables prefixed PUBLIC_ are exposed to the site at build time.

# Google AdSense publisher id — from AdSense > Ads > "Get code".
# Looks like: ca-pub-1234567890123456
# Leave empty until approved; ad slots will then show labeled placeholders.
PUBLIC_ADSENSE_CLIENT=

# Google Search Console verification token — the long string from
# Search Console > Settings > Ownership verification > HTML tag method.
PUBLIC_GSC_VERIFICATION=

# Naver Search Advisor (서치어드바이저) verification token — from
# 서치어드바이저 > 사이트 등록 > 메타태그 인증.
PUBLIC_NAVER_VERIFICATION=

# Google Analytics 4 Measurement ID — from GA4 > Admin > Data Streams.
# Looks like: G-XXXXXXXXXX
PUBLIC_GA4_ID=

---
import { t } from '../i18n/ui';
import type { Locale } from '../i18n/config';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const tr = t(lang).dsr;
---

<form id="dsr-calc" class="calc" data-locale="ko-KR">
  <div class="calc__fields">
    <label class="field">
      <span class="field__label">{tr.income}</span>
      <span class="field__input-wrap">
        <span class="field__prefix">₩</span>
        <input type="number" min="0" step="any" data-dsr-income value="50000000" />
      </span>
    </label>
    <label class="field">
      <span class="field__label">{tr.repayment}</span>
      <span class="field__input-wrap">
        <span class="field__prefix">₩</span>
        <input type="number" min="0" step="any" data-dsr-repay value="1500000" />
      </span>
    </label>
  </div>
  <div class="results">
    <div class="result result--primary">
      <span class="result__label">{tr.dsr}</span>
      <span class="result__value" data-dsr-val>—</span>
    </div>
    <div class="rate">
      <span class="rate__label">{tr.assessment}</span>
      <span class="rate__value" data-dsr-assess>—</span>
    </div>
  </div>
  <p class="calc__note">{tr.note}</p>
  <script is:inline src="/js/dsr.js" defer></script>
</form>

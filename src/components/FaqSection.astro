---
import type { Locale } from '../i18n/config';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const ko = lang === 'ko';

const faqs = ko
  ? [
      {
        q: '계산 결과는 정확한가요?',
        a: '표준 금융 수식과 공식 환율·세율을 사용하지만 결과는 참고용입니다. 중요한 결정은 반드시 전문가와 확인하세요.',
      },
      {
        q: '입력한 정보는 저장되나요?',
        a: '아니요. 모든 계산은 브라우저에서만 처리되며, 서버로 전송하거나 저장하지 않습니다.',
      },
      {
        q: '무료로 사용할 수 있나요?',
        a: '네, 완전 무료이며 회원가입이나 로그인 없이 바로 이용할 수 있습니다.',
      },
    ]
  : [
      {
        q: 'Are the results accurate?',
        a: 'We use standard financial formulas and official rates, but results are for reference only. Confirm important decisions with a professional.',
      },
      {
        q: 'Is my input data stored?',
        a: 'No. All calculations run only in your browser — nothing is sent to or stored on our servers.',
      },
      {
        q: 'Is it free to use?',
        a: 'Yes, completely free, with no sign-up or login required.',
      },
    ];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<section class="container section faq">
  <h2 class="section__title">{ko ? '자주 묻는 질문' : 'Frequently asked questions'}</h2>
  {faqs.map((f) => (
    <details class="faq__item">
      <summary>{f.q}</summary>
      <p>{f.a}</p>
    </details>
  ))}
</section>

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

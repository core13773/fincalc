---
import { getTaxTable, computeIncomeTax } from '../data/tax';
import { t } from '../i18n/ui';
import type { Locale } from '../i18n/config';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const tr = t(lang).incomeTax;
const locale = lang === 'ko' ? 'ko-KR' : 'en-US';

const table = getTaxTable(locale);
const defaultAmount = lang === 'ko' ? 50000000 : 80000;
const init = computeIncomeTax(locale, defaultAmount);

const fmt = (v: number) =>
  new Intl.NumberFormat(locale, {
    style: 'currency',
    currency: table.currency,
    maximumFractionDigits: 0,
  }).format(v);
const pct = (r: number) => (r * 100).toFixed(1) + '%';
---

<form id="income-tax-calc" class="calc" data-locale={locale}>
  <label class="field">
    <span class="field__label">{tr.taxableAmount}</span>
    <span class="field__input-wrap">
      <span class="field__prefix">{table.currency === 'KRW' ? '₩' : '$'}</span>
      <input type="number" name="amount" inputmode="decimal" min="0" step="any"
        value={defaultAmount} data-tax-amount />
    </span>
  </label>

  <div class="results">
    <div class="result result--primary">
      <span class="result__label">{tr.totalTax}</span>
      <span class="result__value" data-tax-total>{fmt(init.totalTax)}</span>
    </div>
    <div class="result-grid three">
      <div class="result">
        <span class="result__label">{tr.incomeTax}</span>
        <span class="result__value" data-tax-income>{fmt(init.incomeTax)}</span>
      </div>
      <div class="result" data-tax-local-wrap style={table.surtax ? '' : 'display:none'}>
        <span class="result__label">{tr.localTax}</span>
        <span class="result__value" data-tax-local>{fmt(init.localTax)}</span>
      </div>
      <div class="result result--accent">
        <span class="result__label">{tr.afterTax}</span>
        <span class="result__value" data-tax-after>{fmt(init.afterTax)}</span>
      </div>
    </div>
    <div class="rate">
      <span class="rate__label">{tr.effectiveRate}</span>
      <span class="rate__value" data-tax-rate>{pct(init.effectiveRate)}</span>
    </div>
  </div>

  <p class="calc__note">{tr.note}</p>

  <script type="application/json" id="tax-data" set:html={JSON.stringify({
    table,
    locale,
  })} />
  <script is:inline src="/js/income-tax.js" defer></script>
</form>

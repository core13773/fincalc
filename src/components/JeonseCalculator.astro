---
import { t } from '../i18n/ui';
import type { Locale } from '../i18n/config';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const tr = t(lang).jeonse;
---

<form id="jeonse-calc" class="calc" data-locale="ko-KR">
  <h3 class="calc__subtitle">{tr.rateTitle}</h3>
  <div class="calc-row">
    <label class="field">
      <span class="field__label">{tr.deposit}</span>
      <span class="field__input-wrap"><span class="field__prefix">₩</span><input type="number" min="0" step="any" data-je-dep1 value="100000000" /></span>
    </label>
    <label class="field">
      <span class="field__label">{tr.rent}</span>
      <span class="field__input-wrap"><span class="field__prefix">₩</span><input type="number" min="0" step="any" data-je-rent1 value="500000" /></span>
    </label>
    <span class="pct-eq">=</span>
    <span class="result-inline" data-je-rate>—</span>
  </div>

  <h3 class="calc__subtitle">{tr.depToRent}</h3>
  <div class="calc-row">
    <label class="field">
      <span class="field__label">{tr.deposit}</span>
      <span class="field__input-wrap"><span class="field__prefix">₩</span><input type="number" min="0" step="any" data-je-dep2 value="100000000" /></span>
    </label>
    <label class="field field--narrow">
      <span class="field__label">{tr.rate}</span>
      <input type="number" min="0" step="0.01" data-je-rate2 value="4" />
    </label>
    <span class="pct-eq">=</span>
    <span class="result-inline" data-je-rent2>—</span>
  </div>

  <h3 class="calc__subtitle">{tr.rentToDep}</h3>
  <div class="calc-row">
    <label class="field">
      <span class="field__label">{tr.rent}</span>
      <span class="field__input-wrap"><span class="field__prefix">₩</span><input type="number" min="0" step="any" data-je-rent3 value="500000" /></span>
    </label>
    <label class="field field--narrow">
      <span class="field__label">{tr.rate}</span>
      <input type="number" min="0" step="0.01" data-je-rate3 value="4" />
    </label>
    <span class="pct-eq">=</span>
    <span class="result-inline" data-je-dep3>—</span>
  </div>

  <p class="calc__note">{tr.note}</p>
  <script is:inline src="/js/jeonse.js" defer></script>
</form>

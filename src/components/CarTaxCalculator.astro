---
import { t } from '../i18n/ui';
import type { Locale } from '../i18n/config';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const tr = t(lang).cartax;
---

<form id="cartax-calc" class="calc" data-locale="ko-KR">
  <div class="calc__fields">
    <label class="field">
      <span class="field__label">{tr.price}</span>
      <span class="field__input-wrap">
        <span class="field__prefix">₩</span>
        <input type="number" min="0" step="any" data-ct-price value="30000000" />
      </span>
    </label>
    <label class="field">
      <span class="field__label">{tr.type}</span>
      <select data-ct-type>
        <option value="7">{tr.sedan}</option>
        <option value="0">{tr.light}</option>
        <option value="5">{tr.cargo}</option>
      </select>
    </label>
  </div>
  <div class="results">
    <div class="result result--primary">
      <span class="result__label">{tr.tax}</span>
      <span class="result__value" data-ct-tax>—</span>
    </div>
    <div class="rate">
      <span class="rate__label">{tr.rate}</span>
      <span class="rate__value" data-ct-rate>—</span>
    </div>
  </div>
  <p class="calc__note">{tr.note}</p>
  <script is:inline src="/js/cartax.js" defer></script>
</form>

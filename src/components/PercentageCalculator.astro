---
import { t } from '../i18n/ui';
import type { Locale } from '../i18n/config';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const tr = t(lang).percentage;
const locale = lang === 'ko' ? 'ko-KR' : 'en-US';
---

<form id="percentage-calc" class="calc" data-locale={locale} data-inc={tr.increase} data-dec={tr.decrease}>
  <h3 class="calc__subtitle">{tr.ofTitle}</h3>
  <div class="calc-row">
    <label class="field">
      <span class="field__label">{tr.ofWhole}</span>
      <input type="number" name="of-whole" inputmode="decimal" step="any" value="200" data-pct-of-whole />
    </label>
    <label class="field">
      <span class="field__label">{tr.ofPercent}</span>
      <input type="number" name="of-percent" inputmode="decimal" step="any" value="15" data-pct-of-percent />
    </label>
    <span class="pct-eq">=</span>
    <span class="result-inline" data-pct-of-result>30</span>
  </div>

  <h3 class="calc__subtitle">{tr.ratioTitle}</h3>
  <div class="calc-row">
    <label class="field">
      <span class="field__label">{tr.ratioA}</span>
      <input type="number" name="ratio-a" inputmode="decimal" step="any" value="30" data-pct-ratio-a />
    </label>
    <label class="field">
      <span class="field__label">{tr.ratioB}</span>
      <input type="number" name="ratio-b" inputmode="decimal" step="any" value="200" data-pct-ratio-b />
    </label>
    <span class="pct-eq">=</span>
    <span class="result-inline" data-pct-ratio-result>15%</span>
  </div>

  <h3 class="calc__subtitle">{tr.changeTitle}</h3>
  <div class="calc-row">
    <label class="field">
      <span class="field__label">{tr.changePrev}</span>
      <input type="number" name="chg-prev" inputmode="decimal" step="any" value="100" data-pct-chg-prev />
    </label>
    <label class="field">
      <span class="field__label">{tr.changeNext}</span>
      <input type="number" name="chg-next" inputmode="decimal" step="any" value="120" data-pct-chg-next />
    </label>
    <span class="pct-eq">=</span>
    <span class="result-inline" data-pct-chg-result>+20%</span>
  </div>

  <p class="calc__note">{tr.note}</p>

  <script is:inline src="/js/percentage.js" defer></script>
</form>

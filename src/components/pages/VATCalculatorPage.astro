---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSlot from '../AdSlot.astro';
import VATCalculator from '../VATCalculator.astro';
import { t } from '../../i18n/ui';
import { localizePath, type Locale } from '../../i18n/config';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const tr = t(lang);
const vat = tr.vat;

const related = [
  { href: localizePath(lang, '/percentage'), label: tr.nav.percentage },
  { href: localizePath(lang, '/loan-calculator'), label: tr.nav.loan },
  { href: localizePath(lang, '/currency'), label: tr.nav.currency },
];
---

<BaseLayout lang={lang} path="/vat" title={`${vat.title} | FinCalc`} description={vat.description}>
  <section class="page-head container">
    <h1>{vat.title}</h1>
    <p class="page-head__desc">{vat.description}</p>
  </section>

  <div class="container layout-2col">
    <div class="layout-main">
      <VATCalculator lang={lang} />
    </div>
    <aside class="layout-side">
      <AdSlot variant="rectangle" />
    </aside>
  </div>

  <section class="container section">
    <p class="related">
      {related.map((r, i) => (<>
        {i > 0 && ' · '}
        <a href={r.href}>{r.label}</a>
      </>))}
    </p>
  </section>

  <div class="container">
    <AdSlot variant="leaderboard" />
  </div>
</BaseLayout>

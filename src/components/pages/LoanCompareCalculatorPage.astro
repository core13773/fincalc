---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSlot from '../AdSlot.astro';
import LoanCompareCalculator from '../LoanCompareCalculator.astro';
import { t } from '../../i18n/ui';
import { localizePath, type Locale } from '../../i18n/config';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const tr = t(lang);
const lc = tr.loancompare;
const related = [
  { href: localizePath(lang, '/loan-calculator'), label: tr.nav.loan },
  { href: localizePath(lang, '/early-repay'), label: tr.earlyrepay.title },
  { href: localizePath(lang, '/dsr'), label: tr.dsr.title },
];
---

<BaseLayout lang={lang} path="/loan-compare" title={`${lc.title} | FinCalc`} description={lc.description}>
  <section class="page-head container">
    <h1>{lc.title}</h1>
    <p class="page-head__desc">{lc.description}</p>
  </section>

  <div class="container layout-2col">
    <div class="layout-main">
      <LoanCompareCalculator lang={lang} />
    </div>
    <aside class="layout-side">
      <AdSlot variant="rectangle" />
    </aside>
  </div>

  <section class="container section">
    <p class="related">
      {related.map((r, i) => (<>
        {i > 0 && ' · '}
        <a href={r.href}>{r.label}</a>
      </>))}
    </p>
  </section>

  <div class="container">
    <AdSlot variant="leaderboard" />
  </div>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSlot from '../AdSlot.astro';
import YearTaxCalculator from '../YearTaxCalculator.astro';
import { t } from '../../i18n/ui';
import { localizePath } from '../../i18n/config';

const lang = 'ko';
const tr = t(lang);
const y = tr.yeartax;
const related = [
  { href: localizePath(lang, '/salary'), label: tr.salary.title },
  { href: localizePath(lang, '/income-tax'), label: tr.nav.incomeTax },
  { href: localizePath(lang, '/vat'), label: tr.nav.vat },
];
---

<BaseLayout lang={lang} path="/year-tax" title={`${y.title} | FinCalc`} description={y.description}>
  <section class="page-head container">
    <h1>{y.title}</h1>
    <p class="page-head__desc">{y.description}</p>
  </section>

  <div class="container layout-2col">
    <div class="layout-main">
      <YearTaxCalculator lang={lang} />
    </div>
    <aside class="layout-side">
      <AdSlot variant="rectangle" />
    </aside>
  </div>

  <section class="container section">
    <p class="related">
      {related.map((r, i) => (<>
        {i > 0 && ' · '}
        <a href={r.href}>{r.label}</a>
      </>))}
    </p>
  </section>

  <div class="container">
    <AdSlot variant="leaderboard" />
  </div>
</BaseLayout>

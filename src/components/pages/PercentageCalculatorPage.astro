---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSlot from '../AdSlot.astro';
import PercentageCalculator from '../PercentageCalculator.astro';
import { t } from '../../i18n/ui';
import { localizePath, type Locale } from '../../i18n/config';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const tr = t(lang);
const pct = tr.percentage;

const related = [
  { href: localizePath(lang, '/vat'), label: tr.nav.vat },
  { href: localizePath(lang, '/loan-calculator'), label: tr.nav.loan },
  { href: localizePath(lang, '/compound-interest'), label: tr.nav.compound },
];
---

<BaseLayout lang={lang} path="/percentage" title={`${pct.title} | FinCalc`} description={pct.description}>
  <section class="page-head container">
    <h1>{pct.title}</h1>
    <p class="page-head__desc">{pct.description}</p>
  </section>

  <div class="container layout-2col">
    <div class="layout-main">
      <PercentageCalculator lang={lang} />
    </div>
    <aside class="layout-side">
      <AdSlot variant="rectangle" />
    </aside>
  </div>

  <section class="container section">
    <p class="related">
      {related.map((r, i) => (<>
        {i > 0 && ' · '}
        <a href={r.href}>{r.label}</a>
      </>))}
    </p>
  </section>

  <div class="container">
    <AdSlot variant="leaderboard" />
  </div>
</BaseLayout>

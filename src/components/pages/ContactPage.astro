---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/ui';
import { type Locale } from '../../i18n/config';
import { CONTACT_EMAIL } from '../../consts';

interface Props { lang: Locale; }
const { lang } = Astro.props;
const tr = t(lang);
const ko = lang === 'ko';
---

<BaseLayout
  lang={lang}
  path="/contact"
  title={`${tr.footer.legal.contact} | FinCalc`}
  description={ko
    ? 'FinCalc에 문의하기 — 제안, 오류 신고, 협업 문의를 이메일로 보내주세요.'
    : 'Contact FinCalc — send us your suggestions, bug reports, or partnership inquiries by email.'}
>
  <section class="page-head container">
    <h1>{tr.footer.legal.contact}</h1>
    <p class="page-head__desc">{ko
      ? '제안, 오류 신고 또는 협업 문의가 있으시면 아래 이메일로 연락해 주세요.'
      : 'Have a suggestion, found a bug, or want to work with us? Reach us at the email below.'}</p>
  </section>

  <div class="container layout-prose">
    <div class="prose">
      <h2>{ko ? '이메일' : 'Email'}</h2>
      <p>
        <a class="contact-email" href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
      </p>
      <p>{ko
        ? '가능한 한 빨리 답변드리겠습니다. 계산 결과에 대한 개별 금융 자문은 제공하지 않습니다.'
        : 'We reply as soon as we can. Please note we do not provide personalized financial advice on calculation results.'}</p>
    </div>
  </div>
</BaseLayout>

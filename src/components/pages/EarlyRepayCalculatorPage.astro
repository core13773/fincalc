---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AdSlot from '../AdSlot.astro';
import EarlyRepayCalculator from '../EarlyRepayCalculator.astro';
import { t } from '../../i18n/ui';
import { localizePath } from '../../i18n/config';

const lang = 'ko';
const tr = t(lang);
const e = tr.earlyrepay;
const related = [
  { href: localizePath(lang, '/loan-calculator'), label: tr.nav.loan },
  { href: localizePath(lang, '/dsr'), label: tr.dsr.title },
  { href: localizePath(lang, '/loan-compare'), label: tr.loancompare.title },
];
---

<BaseLayout lang={lang} path="/early-repay" title={`${e.title} | FinCalc`} description={e.description}>
  <section class="page-head container">
    <h1>{e.title}</h1>
    <p class="page-head__desc">{e.description}</p>
  </section>

  <div class="container layout-2col">
    <div class="layout-main">
      <EarlyRepayCalculator lang={lang} />
    </div>
    <aside class="layout-side">
      <AdSlot variant="rectangle" />
    </aside>
  </div>

  <section class="container section">
    <p class="related">
      {related.map((r, i) => (<>
        {i > 0 && ' · '}
        <a href={r.href}>{r.label}</a>
      </>))}
    </p>
  </section>

  <div class="container">
    <AdSlot variant="leaderboard" />
  </div>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DsrCalculator from '../DsrCalculator.astro';
import { t } from '../../i18n/ui';
import { localizePath } from '../../i18n/config';

const lang = 'ko';
const tr = t(lang);
const s = tr.dsr;
const related = [
  { href: localizePath(lang, '/loan-calculator'), label: tr.nav.loan },
  { href: localizePath(lang, '/salary'), label: tr.salary.title },
  { href: localizePath(lang, '/income-tax'), label: tr.nav.incomeTax },
];
---

<BaseLayout lang={lang} path="/dsr" title={`${s.title} | FinCalc`} description={s.description}>
  <section class="page-head container">
    <h1>{s.title}</h1>
    <p class="page-head__desc">{s.description}</p>
  </section>

  <div class="container layout-2col">
    <div class="layout-main">
      <DsrCalculator lang={lang} />
    </div>
    <aside class="layout-side">
    </aside>
  </div>

  <section class="container section">
    <p class="related">
      {related.map((r, i) => (<>
        {i > 0 && ' · '}
        <a href={r.href}>{r.label}</a>
      </>))}
    </p>
  </section>

  <div class="container">
  </div>
</BaseLayout>

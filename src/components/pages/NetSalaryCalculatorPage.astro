---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NetSalaryCalculator from '../NetSalaryCalculator.astro';
import { t } from '../../i18n/ui';
import { localizePath, type Locale } from '../../i18n/config';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const tr = t(lang);
const s = tr.salary;

const related = [
  { href: localizePath(lang, '/income-tax'), label: tr.nav.incomeTax },
  { href: localizePath(lang, '/vat'), label: tr.nav.vat },
  { href: localizePath(lang, '/loan-calculator'), label: tr.nav.loan },
];
---

<BaseLayout lang={lang} path="/salary" title={`${s.title} | FinCalc`} description={s.description}>
  <section class="page-head container">
    <h1>{s.title}</h1>
    <p class="page-head__desc">{s.description}</p>
  </section>

  <div class="container layout-2col">
    <div class="layout-main">
      <NetSalaryCalculator lang={lang} />
    </div>
    <aside class="layout-side">
    </aside>
  </div>

  <section class="container section">
    <p class="related">
      {related.map((r, i) => (<>
        {i > 0 && ' · '}
        <a href={r.href}>{r.label}</a>
      </>))}
    </p>
  </section>

  <div class="container">
  </div>
</BaseLayout>

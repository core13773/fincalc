---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CompoundInterestCalculator from '../CompoundInterestCalculator.astro';
import { t } from '../../i18n/ui';
import { localizePath, type Locale } from '../../i18n/config';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const tr = t(lang);
const compound = tr.compound;

const related = [
  { href: localizePath(lang, '/loan-calculator'), label: tr.nav.loan },
  { href: localizePath(lang, '/currency'), label: tr.nav.currency },
];
---

<BaseLayout lang={lang} title={`${compound.title} | FinCalc`} description={compound.description} path="/compound-interest">
  <section class="page-head container">
    <h1>{compound.title}</h1>
    <p class="page-head__desc">{compound.description}</p>
  </section>

  <div class="container layout-2col">
    <div class="layout-main">
      <CompoundInterestCalculator lang={lang} />
    </div>
    <aside class="layout-side">
    </aside>
  </div>

  <section class="container section">
    <h2 class="section__title">{compound.howToTitle}</h2>
    <ol class="howto">
      {compound.howTo.map((step) => <li>{step}</li>)}
    </ol>
    <p class="related">
      {related.map((r, i) => (<>
        {i > 0 && ' · '}
        <a href={r.href}>{r.label}</a>
      </>))}
    </p>
  </section>

  <div class="container">
  </div>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DividendCalculator from '../DividendCalculator.astro';
import { t } from '../../i18n/ui';
import { localizePath, type Locale } from '../../i18n/config';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const tr = t(lang);
const d = tr.dividend;
const related = [
  { href: localizePath(lang, '/stock'), label: tr.stock.title },
  { href: localizePath(lang, '/compound-interest'), label: tr.nav.compound },
  { href: localizePath(lang, '/income-tax'), label: tr.nav.incomeTax },
];
---

<BaseLayout lang={lang} path="/dividend" title={`${d.title} | FinCalc`} description={d.description}>
  <section class="page-head container">
    <h1>{d.title}</h1>
    <p class="page-head__desc">{d.description}</p>
  </section>

  <div class="container layout-2col">
    <div class="layout-main">
      <DividendCalculator lang={lang} />
    </div>
    <aside class="layout-side">
    </aside>
  </div>

  <section class="container section">
    <p class="related">
      {related.map((r, i) => (<>
        {i > 0 && ' · '}
        <a href={r.href}>{r.label}</a>
      </>))}
    </p>
  </section>

  <div class="container">
  </div>
</BaseLayout>

---
import { localizePath, type Locale } from '../i18n/config';
import { t } from '../i18n/ui';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const tr = t(lang);
const year = new Date().getFullYear();

const tools = [
  { href: '/loan-calculator', label: tr.nav.loan },
  { href: '/compound-interest', label: tr.nav.compound },
  { href: '/currency', label: tr.nav.currency },
  { href: '/unit', label: tr.nav.unit },
  { href: '/percentage', label: tr.nav.percentage },
  { href: '/vat', label: tr.nav.vat },
  { href: '/income-tax', label: tr.nav.incomeTax },
  { href: '/age', label: tr.nav.age },
].map((x) => ({ ...x, href: localizePath(lang, x.href) }));

const legal = [
  { href: localizePath(lang, '/privacy'), label: tr.footer.legal.privacy },
  { href: localizePath(lang, '/about'), label: tr.footer.legal.about },
  { href: localizePath(lang, '/contact'), label: tr.footer.legal.contact },
];
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <strong>{tr.site.name}</strong>
      <span class="footer-tag">{tr.footer.about}</span>
    </div>

    <nav class="footer-nav" aria-label="Tools">
      {tools.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>

    <nav class="footer-nav footer-legal" aria-label="Legal">
      {legal.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>

    <p class="disclaimer">{tr.common.disclaimer}</p>
    <p class="copyright">© {year} {tr.site.name}. {tr.footer.rights}</p>
  </div>
</footer>

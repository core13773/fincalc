---
import { localizePath, otherLocale, type Locale } from '../i18n/config';
import { t } from '../i18n/ui';

interface Props {
  lang: Locale;
  path?: string;
}
const { lang, path = '' } = Astro.props;
const tr = t(lang);

const homeHref = localizePath(lang, '');
const nav = [
  { href: homeHref, label: tr.nav.home },
  { href: localizePath(lang, '/loan-calculator'), label: tr.nav.loan },
  { href: localizePath(lang, '/compound-interest'), label: tr.nav.compound },
  { href: localizePath(lang, '/currency'), label: tr.nav.currency },
  { href: localizePath(lang, '/percentage'), label: tr.nav.percentage },
  { href: localizePath(lang, '/vat'), label: tr.nav.vat },
];

const current = localizePath(lang, path);
const isActive = (href: string) =>
  href === homeHref ? current === href : current.startsWith(href);

const switchHref = localizePath(otherLocale(lang), path);
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={homeHref}>
      <span class="brand-mark" aria-hidden="true">₩</span>
      <span>{tr.site.name}</span>
    </a>

    <nav class="main-nav" aria-label="Primary">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={['nav-link', { active: isActive(item.href) }]}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <a
      class="lang-switch"
      href={switchHref}
      hreflang={otherLocale(lang)}
      title={tr.nav.switchTo}
    >
      {tr.nav.switchLabel}
    </a>
  </div>
</header>

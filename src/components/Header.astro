---
import { localizePath, otherLocale, type Locale } from '../i18n/config';
import { t } from '../i18n/ui';

interface Props {
  lang: Locale;
  path?: string;
}
const { lang, path = '' } = Astro.props;
const tr = t(lang);

const homeHref = localizePath(lang, '');
const nav = [
  { href: homeHref, label: tr.nav.home },
  { href: localizePath(lang, '/loan-calculator'), label: tr.nav.loan },
  { href: localizePath(lang, '/compound-interest'), label: tr.nav.compound },
  { href: localizePath(lang, '/currency'), label: tr.nav.currency },
  { href: localizePath(lang, '/unit'), label: tr.nav.unit },
  { href: localizePath(lang, '/percentage'), label: tr.nav.percentage },
  { href: localizePath(lang, '/vat'), label: tr.nav.vat },
  { href: localizePath(lang, '/income-tax'), label: tr.nav.incomeTax },
  { href: localizePath(lang, '/age'), label: tr.nav.age },
  { href: localizePath(lang, '/date'), label: tr.nav.date },
];

const current = localizePath(lang, path);
const isActive = (href: string) =>
  href === homeHref ? current === href : current.startsWith(href);

const switchHref = localizePath(otherLocale(lang), path);
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href={homeHref}>
      <span class="brand-mark" aria-hidden="true">₩</span>
      <span>{tr.site.name}</span>
    </a>

    <nav class="main-nav" aria-label="Primary">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={['nav-link', { active: isActive(item.href) }]}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <button class="theme-toggle" type="button" data-theme-toggle aria-label="theme"></button>
    <button class="share-btn" type="button" data-share-btn aria-label="share">🔗</button>
    <a
      class="lang-switch"
      href={switchHref}
      hreflang={otherLocale(lang)}
      title={tr.nav.switchTo}
    >
      {tr.nav.switchLabel}
    </a>
  </div>
</header>

<script is:inline set:html={`(function(){var btn=document.querySelector('[data-theme-toggle]');if(!btn)return;function eff(){var dt=document.documentElement.getAttribute('data-theme');if(dt==='dark'||dt==='light')return dt;return (window.matchMedia&&window.matchMedia('(prefers-color-scheme: dark)').matches)?'dark':'light';}function paint(){var d=eff()==='dark';btn.textContent=d?'☀️':'🌙';btn.setAttribute('aria-label',d?'light':'dark');}btn.addEventListener('click',function(){var next=eff()==='dark'?'light':'dark';document.documentElement.setAttribute('data-theme',next);try{localStorage.setItem('theme',next);}catch(e){}paint();});paint();})();`} />

<script is:inline set:html={`(function(){var btn=document.querySelector('[data-share-btn]');if(!btn)return;function done(){var o=btn.textContent;btn.textContent='✓';setTimeout(function(){btn.textContent=o;},1400);}btn.addEventListener('click',function(){var data={title:document.title,url:location.href};if(navigator.share){navigator.share(data).then(done).catch(function(){});}else if(navigator.clipboard){navigator.clipboard.writeText(location.href).then(done).catch(function(){});}else{done();}});})();`} />

---
import BaseLayout from '../layouts/BaseLayout.astro';
import { localizePath } from '../i18n/config';

const links = [
  { href: localizePath('ko', '/loan-calculator'), ko: '대출 계산기', en: 'Loan calculator' },
  { href: localizePath('ko', '/compound-interest'), ko: '복리 계산기', en: 'Compound interest' },
  { href: localizePath('ko', '/currency'), ko: '환율 계산기', en: 'Currency converter' },
  { href: localizePath('ko', '/percentage'), ko: '퍼센트 계산기', en: 'Percentage calculator' },
  { href: localizePath('ko', '/vat'), ko: '부가세 계산기', en: 'VAT calculator' },
];
---

<BaseLayout lang="ko" path="/404" noindex={true} title="404 | FinCalc" description="Page not found.">
  <section class="container notfound">
    <p class="notfound__code">404</p>
    <h1>페이지를 찾을 수 없습니다 <span class="muted">/ Page not found</span></h1>
    <p class="muted">
      요청하신 페이지가 존재하지 않거나 이동되었습니다.
      <br />
      The page you're looking for doesn't exist or has moved.
    </p>

    <div class="hero__cta">
      <a class="btn btn--primary" href={localizePath('ko', '')}>홈으로</a>
      <a class="btn btn--ghost" href={localizePath('en', '')}>Go to English home</a>
    </div>

    <ul class="notfound__links">
      {links.map((l) => <li><a href={l.href}>{l.ko} · {l.en}</a></li>)}
    </ul>
  </section>
</BaseLayout>

<style>
  .notfound { text-align: center; padding: 64px 0; max-width: 640px; }
  .notfound__code { font-size: 4rem; font-weight: 800; color: var(--primary); margin: 0; }
  .notfound__links { list-style: none; padding: 0; margin: 28px 0 0; display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; }
  .notfound__links a { padding: 6px 12px; border: 1px solid var(--border); border-radius: 999px; font-size: 0.88rem; font-weight: 600; color: var(--text); }
  .notfound__links a:hover { border-color: var(--primary); color: var(--primary); text-decoration: none; }
  .muted { color: var(--muted); }
</style>

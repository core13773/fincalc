---
import { DEFAULT_SITE_ORIGIN, GSC_VERIFICATION, NAVER_VERIFICATION, GA4_ID } from '../consts';
import {
  hreflangCode,
  localizePath,
  locales,
  defaultLocale,
  type Locale,
} from '../i18n/config';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FaqSection from '../components/FaqSection.astro';
import '../styles/global.css';

interface Props {
  lang: Locale;
  title: string;
  description: string;
  /** Path without the locale prefix, e.g. '/loan-calculator'. '' = locale home. */
  path?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown>;
}

const { lang, title, description, path = '', noindex = false, jsonLd } = Astro.props;

const origin = Astro.site?.origin ?? DEFAULT_SITE_ORIGIN;
const canonicalURL = new URL(localizePath(lang, path), origin).href;

const alternates = locales.map((l) => ({
  hreflang: l,
  href: new URL(localizePath(l, path), origin).href,
}));
const xdefaultURL = new URL(localizePath(defaultLocale, path), origin).href;
const ogLocale = hreflangCode(lang).replace('-', '_');
---

<!doctype html>
<html lang={lang === 'ko' ? 'ko' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <script is:inline set:html={`(function(){try{var t=localStorage.getItem('theme');if(t==='dark'||t==='light'){document.documentElement.setAttribute('data-theme',t);}}catch(e){}})();`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}
    <link rel="alternate" hreflang="x-default" href={xdefaultURL} />

    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {!noindex && <meta name="robots" content="index, follow" />}

    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content="FinCalc" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    {GSC_VERIFICATION && (
      <meta name="google-site-verification" content={GSC_VERIFICATION} />
    )}

    {NAVER_VERIFICATION && (
      <meta name="naver-site-verification" content={NAVER_VERIFICATION} />
    )}

    <meta name="520fc725a254a0e670d098250d8d8116f2e763ee" content="520fc725a254a0e670d098250d8d8116f2e763ee" />

    {/* HilltopAds */}
    <script is:inline data-cfasync="false" type="text/javascript" src="https://pleased-report.com/bh3aVP0.Pz3BpBv/bnmiVhJaZ/DB0z3LMSTgg-w/MrzlULz/LRTJcFx_OtDdArzXNMTxcd"></script>
    {/* HilltopAds — native/push (desktop & mobile) */}
    <script is:inline>
      (function(hwxd){
        var d = document,
          s = d.createElement('script'),
          l = d.scripts[d.scripts.length - 1];
        s.settings = hwxd || {};
        s.src = "//massivesalad.com/bfXGV/s.dyGqly0vYXW_cs/-ermJ9-uOZCUZlgk/P/TKcExuOXDqAb0eO/TeM/tDNwz/EA4QMPDVQt5/NtwA";
        s.async = true;
        s.referrerPolicy = 'no-referrer-when-downgrade';
        l.parentNode.insertBefore(s, l);
      })({})
    </script>

    {/* Google Analytics 4 — active only when PUBLIC_GA4_ID is set */}
    {GA4_ID && (
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}></script>
    )}
    {GA4_ID && (
      <script is:inline set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${GA4_ID}');`} />
    )}
  </head>
  <body>
    <a class="skip-link" href="#main">{lang === 'ko' ? '본문으로 건너뛰기' : 'Skip to content'}</a>
    <Header lang={lang} path={path} />
    <main id="main">
      <slot />
    </main>
    <FaqSection lang={lang} />
    <Footer lang={lang} />
  </body>
</html>
